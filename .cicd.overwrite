---

# General info
generic:
  role_description: |
    Sets up iptables and applies a default rule set.<br>
    For RedHat/CentOS, it will disable firewalld.<br>
    On Alpine, it depends on the presence of OpenRC.

# Supported platforms
platforms:
  ubuntu2004:
    supported: true
    ci: true
  alpine3:
    supported: true
    ci: true

